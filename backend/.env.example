# ── AI 제공자 선택 ──────────────────────────────────────
# anthropic 또는 deepseek 중 하나를 입력하세요
AI_PROVIDER=anthropic

# ── Anthropic (Claude) API 키 ────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에입력

# ── DeepSeek API 키 ──────────────────────────────────────
# https://platform.deepseek.com 에서 발급 (가입 시 무료 크레딧 제공)
DEEPSEEK_API_KEY=sk-여기에입력

PORT=3000
